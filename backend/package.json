{
  "name": "modelo-padrao-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env.dev src/index.js",
    "start": "node src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "sync:full": "node --env-file=.env src/sync/fullLoad.js",
    "sync:pfalunos": "node --env-file=.env src/sync/loadPfAlunos.js",
    "sync:pfplantoes": "node --env-file=.env src/sync/loadPfPlantoes.js",
    "sync:serasa": "node --env-file=.env src/sync/loadSerasa.js",
    "sync:blip": "node --env-file=.env src/sync/loadBlip.js"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "puppeteer-core": "^24.41.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "better-sqlite3": "^12.8.0",
    "prisma": "^6.9.0"
  }
