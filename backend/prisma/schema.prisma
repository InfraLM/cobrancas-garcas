  id              String   @id @default(uuid())
  nomeBlip        String   @unique       // nome cadastrado e aprovado na Blip/Meta
  titulo          String                 // titulo interno amigavel
  descricao       String?
  conteudoPreview String                 // corpo do template com {{1}} {{2}} etc
  variaveis       Json                   // [{ indice: 1, fonte: 'VALOR_PARCELA' }, ...]
  categoria       String                 // PRE_VENCIMENTO | POS_VENCIMENTO | OUTRO
  escopo          String   @default("AMBOS") // AMBOS | TITULO — inferido pelas variaveis
  ativo           Boolean  @default(true)
  criadoPor       Int
  criadoPorNome   String?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  etapas          EtapaRegua[]

  @@index([categoria, ativo])
  @@map("template_blip")
}

model ReguaCobranca {
  id                  String   @id @default(uuid())
  nome                String
  descricao           String?
  ativo               Boolean  @default(false)
  horarioPadrao       String   @default("09:00") // HH:MM
  intervaloDisparoSeg Int      @default(2)
  criadoPor           Int
  criadoPorNome       String?
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt
  ultimaExecucao      DateTime?

  etapas                EtapaRegua[]
  segmentacoesEmbutidas RegraSegmentacao[] @relation("SegmentacoesEmbutidas")

  @@index([ativo])
  @@map("regua_cobranca")
}

model EtapaRegua {
  id                String   @id @default(uuid())
  reguaId           String
  nome              String
  ordem             Int      @default(0)
  diasRelativoVenc  Int                    // negativo = antes, positivo = depois
  horario           String?                // HH:MM override do padrao da regua
  templateBlipId    String
  filtroRecorrencia String   @default("QUALQUER") // ATIVA | INATIVA | QUALQUER
  filtroSituacao    String   @default("AR")        // AR | RE | QUALQUER
  tiposOrigem       String[] @default([])          // ['MEN','MAT'...]
  segmentacaoId     String?                         // FK opcional a RegraSegmentacao
  ativo             Boolean  @default(true)
  ultimaExecucaoEm  DateTime?                       // quando o scheduler processou esta etapa pela ultima vez
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  regua             ReguaCobranca @relation(fields: [reguaId], references: [id], onDelete: Cascade)
  template          TemplateBlip  @relation(fields: [templateBlipId], references: [id])

  @@index([reguaId, ativo])
  @@index([templateBlipId])
  @@index([ultimaExecucaoEm])
  @@map("etapa_regua")
}

model DisparoMensagem {
  id                 String    @id @default(uuid())
  reguaId            String?
  etapaReguaId       String?
  templateBlipId     String
  templateNomeBlip   String                // snapshot do nome Blip
  pessoaCodigo       Int
  pessoaNome         String
  contaReceberCodigo Int?
  telefone           String
  parametros         Json                  // { "1": "R$ 100,00", ... }

  status             String    @default("PENDENTE") // PENDENTE | ENVIADO | FALHOU | CANCELADO
  tentativas         Int       @default(0)
  blipMessageId      String?
  erroMensagem       String?
  origem             String    @default("REGUA_AUTO") // REGUA_AUTO | DISPARO_MANUAL

  criadoEm           DateTime  @default(now())
  disparadoEm        DateTime?
  atualizadoEm       DateTime  @updatedAt

  convertido         Boolean   @default(false)
  convertidoEm       DateTime?
  diasAteConversao   Int?

  @@unique([etapaReguaId, pessoaCodigo, contaReceberCodigo])
  @@index([status, criadoEm])
  @@index([reguaId, disparadoEm])
  @@index([pessoaCodigo])
  @@index([templateBlipId])
  @@map("disparo_mensagem")
}

// ============================================================
// WORKFLOW DE NEGOCIACOES
// ============================================================

model AcordoFinanceiro {
  id                          String    @id @default(uuid())
  pessoaCodigo                Int
  pessoaNome                  String
  pessoaCpf                   String
  matricula                   String?
  turmaIdentificador          String?
  cursoNome                   String?
  celularAluno                String?
  emailAluno                  String?

  etapa                       String    @default("SELECAO")

  // Valores financeiros
  valorOriginal               Decimal   @db.Decimal(12,2)
  valorMultaJuros             Decimal   @db.Decimal(12,2)
  valorDescontos              Decimal   @db.Decimal(12,2) @default(0)
  valorRecebidoPrevio         Decimal   @db.Decimal(12,2) @default(0)
  valorSaldoDevedor           Decimal   @db.Decimal(12,2)
  descontoAcordo              Decimal   @db.Decimal(12,2) @default(0)
  descontoAcordoPercentual    Decimal?  @db.Decimal(5,2)
  valorAcordo                 Decimal   @db.Decimal(12,2)

  // Recorrencia
  vincularRecorrencia         Boolean   @default(false)

  // Integracoes externas
  asaasCustomerId             String?
  clicksignEnvelopeId         String?
  clicksignDocumentId         String?
  clicksignSignerId           String?
  negociacaoContaReceberCodigo Int?

  // Controle
  criadoPor                   Int       // userId
  criadoPorNome               String
  observacao                  String?
  motivoCancelamento          String?

  // Timestamps
  criadoEm                    DateTime  @default(now())
  atualizadoEm                DateTime  @updatedAt
  termoEnviadoEm              DateTime?
  termoAssinadoEm             DateTime?
  acordoGeradoEm              DateTime?
  concluidoEm                 DateTime?
  seiVinculadoEm              DateTime?
  canceladoEm                 DateTime?

  // Relacoes
  parcelasOriginais           ParcelaOriginalAcordo[]
  pagamentos                  PagamentoAcordo[]
  documento                   Documento?

  @@index([etapa])
  @@index([pessoaCodigo])
  @@index([criadoPor])
  @@index([etapa, concluidoEm])
  @@map("acordo_financeiro")
}

model ParcelaOriginalAcordo {
  id                 String   @id @default(uuid())
  acordoId           String
  contaReceberCodigo Int
  parcela            String?
  valor              Decimal  @db.Decimal(12,2)
  multa              Decimal  @db.Decimal(12,2) @default(0)
  juro               Decimal  @db.Decimal(12,2) @default(0)
  descontos          Decimal  @db.Decimal(12,2) @default(0)
  valorRecebido      Decimal  @db.Decimal(12,2) @default(0)
  saldoDevedor       Decimal  @db.Decimal(12,2)
  dataVencimento     DateTime
  tipoOrigem         String?

  acordo             AcordoFinanceiro @relation(fields: [acordoId], references: [id], onDelete: Cascade)

  @@index([acordoId])
  @@map("parcela_original_acordo")
}

model PagamentoAcordo {
  id                  String    @id @default(uuid())
  acordoId            String
  numeroPagamento     Int
  valor               Decimal   @db.Decimal(12,2)
  formaPagamento      String
  parcelas            Int       @default(1)
  dataVencimento      DateTime
  descricao           String?

  situacao            String    @default("PENDENTE")

  // Asaas
  asaasPaymentId      String?   @unique
  asaasInstallmentId  String?
  asaasInvoiceUrl     String?
  asaasPixQrCode      String?
  asaasBankSlipUrl    String?

  // Confirmacao
  dataPagamento       DateTime?
  valorPago           Decimal?  @db.Decimal(12,2)
  valorLiquido        Decimal?  @db.Decimal(12,2)
  taxaAsaas           Decimal?  @db.Decimal(12,2)

  // Ultima mensagem de erro da API do Asaas (preenchido quando situacao='ERRO')
  erroMensagem        String?

  acordo              AcordoFinanceiro @relation(fields: [acordoId], references: [id], onDelete: Cascade)

  @@index([acordoId])
  @@index([situacao])
  @@map("pagamento_acordo")
}

model Documento {
  id                    String    @id @default(uuid())
  acordoId              String    @unique
  tipo                  String    @default("TERMO_ACORDO")
  clicksignDocumentKey  String?
  clicksignEnvelopeId   String?
  situacao              String    @default("RASCUNHO")
  urlOriginal           String?
  urlAssinado           String?
  pdfAssinado           Bytes?    // PDF assinado baixado da ClickSign
  signatarios           Json?
  enviadoEm             DateTime?
  assinadoEm            DateTime?

  acordo                AcordoFinanceiro @relation(fields: [acordoId], references: [id], onDelete: Cascade)

  @@map("documento")
}

// ============================================================
// WORKFLOW DE RECORRENCIA
// ============================================================

model CadastroRecorrencia {
  id                    String    @id @default(uuid())
  pessoaCodigo          Int
  pessoaNome            String
  pessoaCpf             String
  matricula             String?
  celularAluno          String?

  etapa                 String    @default("PENDENTE") // PENDENTE, MONITORANDO, CONCLUIDO, CANCELADO
  origem                String    // MANUAL, NEGOCIACAO, RECONVERSAO
  metodo                String?   // PARCELA_SIMBOLICA, ATIVACAO_MANUAL

  // Vinculo negociacao
  acordoId              String?

  // Parcela simbolica
  contaReceberCodigo    Int?
  parcelaPaga           Boolean   @default(false)

  // Deteccao
  recorrenciaAtivada    Boolean   @default(false)
  cartaoDetectadoCodigo Int?

  // Controle
  dataLimite            DateTime?
  criadoPor             Int
  criadoPorNome         String
  observacao            String?

  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt
  concluidoEm           DateTime?
  canceladoEm           DateTime?

  @@index([etapa])
  @@index([pessoaCodigo])
  @@map("cadastro_recorrencia")
}

// ============================================================
// TABELA RESUMO DE ALUNOS (substitui mv_aluno_resumo)
// ============================================================

model AlunoResumo {
  codigo              Int       @id
  nome                String
  cpf                 String?
  celular             String?
  matricula           String?
  matSituacao          String?
  naoEnviarMsg        Boolean   @default(false)
  situacao            String    // ATIVO, TRANCADO, CANCELADO
  valorDevedor        Decimal   @db.Decimal(12,2) @default(0)
  parcelasAtraso      Int       @default(0)
  valorPago           Decimal   @db.Decimal(12,2) @default(0)
  situacaoFinanceira  String    // ADIMPLENTE, INADIMPLENTE
  turma               String?
  atualizadoEm        DateTime  @default(now()) @updatedAt

  @@index([situacao])
  @@index([situacaoFinanceira])
  @@index([nome])
  @@map("aluno_resumo")
}

// ============================================================
// WORKFLOW FICOU FACIL (Financiamento Estudantil)
// ============================================================

model FicouFacil {
  id                    String    @id @default(uuid())
  pessoaCodigo          Int
  pessoaNome            String
  pessoaCpf             String
  matricula             String?
  turma                 String?
  celularAluno          String?

  etapa                 String    @default("AGUARDANDO_DOCUMENTACAO")

  // Valores financeiros (pre-preenchidos, editaveis)
  valorPos              Decimal   @db.Decimal(12,2)
  valorRecebido         Decimal   @db.Decimal(12,2)
  valorInadimplente     Decimal   @db.Decimal(12,2)
  valorInadimplenteMJ   Decimal   @db.Decimal(12,2)
  contaSantander        Boolean   @default(false)

  // Checkboxes por etapa (JSON flexivel)
  checkboxes            Json      @default("{}")

  // Analise de credito
  creditoAprovado       Boolean?
  creditoObservacao     String?

  // Controle
  criadoPor             Int
  criadoPorNome         String
  observacao            String?

  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt
  concluidoEm           DateTime?
  canceladoEm           DateTime?

  documentos            DocumentoFicouFacil[]

  @@index([etapa])
  @@index([pessoaCodigo])
  @@map("ficou_facil")
}

model DocumentoFicouFacil {
  id              String    @id @default(uuid())
  ficouFacilId    String
  tipo            String    // DOCUMENTO_ALUNO, DOCUMENTO_AVALISTA
  nomeArquivo     String
  mimeType        String
  tamanho         Int
  arquivo         Bytes
  criadoEm        DateTime  @default(now())

  ficouFacil      FicouFacil @relation(fields: [ficouFacilId], references: [id], onDelete: Cascade)

  @@index([ficouFacilId])
  @@map("documento_ficou_facil")
}

model Atividade {
  id              String    @id @default(uuid())
  tipo            String    // LEMBRETE_MENSAGEM | LEMBRETE_LIGACAO
  titulo          String
  descricao       String?
  status          String    @default("PENDENTE")  // PENDENTE | CONCLUIDA | CANCELADA

  dataHora        DateTime  // quando o agente quer ser lembrado

  // Dono da atividade
  agenteId        Int
  agenteNome      String

  // Aluno alvo (opcional — atalhos rápidos do discador sempre vinculam)
  pessoaCodigo    Int?
  pessoaNome      String?
  telefone        String?   // copiado do registro_ligacao para nao depender de FK

  // Origem (rastreabilidade)
  origem          String    @default("MANUAL")
                            // MANUAL | DURANTE_LIGACAO | DURANTE_CONVERSA
  origemRefId     String?   // callId / conversaId

  metadados       Json?
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt
  concluidoEm     DateTime?

  @@index([agenteId, dataHora])
  @@index([status, dataHora])
  @@index([pessoaCodigo])
  @@map("atividade")
}

// Snapshot diario da inadimplencia. Capturado por job 00:05 (snapshotService.js)
// para permitir reconstruir a "foto" do funil de cobranca em qualquer dia passado.
model SnapshotInadimplenciaDiario {
  data          DateTime  @db.Date
  pessoaCodigo  Int
  valorDevedor  Decimal   @db.Decimal(12, 2)
  capturadoEm   DateTime  @default(now())

  @@id([data, pessoaCodigo])
  @@index([data])
  @@map("snapshot_inadimplencia_diario")
}
