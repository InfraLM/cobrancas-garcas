// -----------------------------------------------
// CRM: Conversa de Cobranca (entidade de dominio)
// Cada conversa WhatsApp vira uma "conversa de cobranca"
// com enriquecimento financeiro e acoes proprias.
// 3C Plus continua como canal; CRM como cerebro.
// -----------------------------------------------
model ConversaCobranca {
  id                      String    @id @default(uuid())

  // Vinculacao com 3C Plus (canal)
  chatId                  String    @unique
  instanciaId             String
  contatoNumero           String
  contatoNome             String?
  contatoImagem           String?

  // Vinculacao com aluno (dominio)
  pessoaCodigo            Int?
  matricula               String?

  // Status de cobranca (nao o da 3C Plus)
  status                  String    @default("AGUARDANDO") // AGUARDANDO, EM_ATENDIMENTO, SNOOZE, ENCERRADA
  motivoEncerramento      String?   // ACORDO_FECHADO, PAGO_AVISTA, SEM_RETORNO, RECUSOU, NAO_E_DEVEDOR, TRANSFERIDO_JURIDICO, OUTRO
  observacaoEncerramento  String?

  // Atribuicao (agente interno, nao 3C Plus)
  agenteId                Int?
  agenteNome              String?
  assumidoEm              DateTime?

  // Snapshot de cobranca (atualizado pelo worker)
  valorInadimplente       Decimal?  @db.Decimal(12, 2)
  diasAtraso              Int?
  serasaAtivo             Boolean   @default(false)
  temAcordoAtivo          Boolean   @default(false)
  acordoId                String?

  // Priorizacao (campos preservados, calculo adiado)
  prioridadeScore         Float     @default(0)
  prioridadeFaixa         String    @default("BAIXA")

  // SLA / metricas
  ultimaMensagemCliente   DateTime?
  ultimaMensagemAgente    DateTime?
  ultimaAtividadeEm       DateTime?
  aguardandoRespostaDesde DateTime?
  reativarEm              DateTime?

  // Preview da ultima mensagem (para listagem)
  ultimaMensagemTexto     String?
  ultimaMensagemTipo      String?
  ultimaMensagemFromMe    Boolean?

  // Contador de mensagens recebidas nao lidas pelo agente
  naoLidos                Int       @default(0)

  criadoEm                DateTime  @default(now())
  atualizadoEm            DateTime  @updatedAt
  encerradoEm             DateTime?

  @@index([status, ultimaAtividadeEm(sort: Desc)])
  @@index([agenteId, status])
  @@index([pessoaCodigo])
  @@index([instanciaId, status])
  @@map("conversa_cobranca")
}

model WebhookEvent {
  id              String    @id @default(uuid())
