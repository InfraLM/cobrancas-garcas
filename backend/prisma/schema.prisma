generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// Usuarios e Autenticacao
// =============================================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  nome      String
  role      String   @default("AGENTE") // ADMIN, SUPERVISOR, AGENTE
  ativo     Boolean  @default(true)

  googleId  String?  @unique
  avatarUrl String?

  threecplusUserId      Int?
  threecplusAgentId     Int?
  threecplusAgentToken  String?
  threecplusExtension   String?

  instanciaWhatsappId   String?
  instanciaWhatsappNome String?
  grupoCanaisId         String?
  grupoCanaisNome       String?

  campanhaId            Int?
  campanhaNome          String?

  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  instanciasWhatsapp InstanciaWhatsappUser[]

  @@map("users")
}

model InstanciaWhatsappUser {
  id           String   @id @default(uuid())
  userId       Int
  instanciaId  String
  apelido      String
  telefone     String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instanciaId])
  @@index([instanciaId])
  @@map("instancia_whatsapp_user")
}

model ErrorLog {
  id        Int      @id @default(autoincrement())
  metodo    String
  url       String
  status    Int
  mensagem  String
  stack     String?
  userId    Int?
  criadoEm  DateTime @default(now())

  @@index([criadoEm(sort: Desc)])
  @@map("error_logs")
}

model RegraSegmentacao {
  id                String    @id @default(uuid())
  nome              String
  descricao         String?
  tipo              String    @default("ALUNO") // ALUNO | TITULO
  condicoes         Json
  ativa             Boolean   @default(true)
  escopoUso         String    @default("GLOBAL") // GLOBAL | EMBUTIDA_REGUA
  reguaOwnerId      String?
  criadoPor         Int
  criadoPorNome     String?
  criadoEm          DateTime  @default(now())
  atualizadoEm      DateTime  @updatedAt
  ultimaExecucao    DateTime?
  totalAlunos       Int?
  totalTitulos      Int?
  valorInadimplente Decimal?  @db.Decimal(12, 2)

  reguaOwner        ReguaCobranca? @relation("SegmentacoesEmbutidas", fields: [reguaOwnerId], references: [id], onDelete: Cascade)

  @@index([ativa])
  @@index([escopoUso, reguaOwnerId])
  @@map("regra_segmentacao")
}

model TemplateWhatsapp {
  id            Int      @id @default(autoincrement())
  nome          String
  categoria     String
  conteudo      String   @db.Text
  icone         String?
  ativo         Boolean  @default(true)
  criadoPor     Int
  criadoPorNome String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoria, ativo])
  @@map("template_whatsapp")
}

