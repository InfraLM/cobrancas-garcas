{
  "buildCommand": "cd backend && npm install && npx prisma generate && cd .. && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/api/index.js" }
  ],
  "functions": {
    "backend/api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
